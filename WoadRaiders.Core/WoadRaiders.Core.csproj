<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Multi-targeted: net10.0 for the server/tests, net8.0 so the Godot client can consume it. -->
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="DotRecast.Detour" Version="2026.1.3" />
    <PackageReference Include="DotRecast.Recast" Version="2026.1.3" />
  </ItemGroup>

  <!--
    Core has ZERO engine and ZERO networking dependencies on purpose.
    It is the authoritative game simulation: it must run identically inside the
    dedicated server, inside unit tests, and (for prediction) inside the client.
  -->

</Project>
