; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="WoadRaiders"
run/main_scene="res://screens/TitleScreen.tscn"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")

[autoload]

MusicJukebox="*res://scripts/MusicJukebox.cs"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="viewport"
window/stretch/aspect="keep_height"

[dotnet]

project/assembly_name="WoadRaiders.Client"

[rendering]

textures/vram_compression/import_etc2_astc=true
; 16x anisotropic (Godot's default is 4x). A chase camera looks down long stone
; halls at grazing angles, the worst case for the procedural surface detail —
; without high anisotropy the joints and pitting shimmer and crawl as you move.
; Near-free on desktop. NOTE: this helps texture ALIASING; it does nothing for
; z-fighting between coplanar faces, which is geometry (see tools/DebugZFight.cs).
textures/default_filters/anisotropic_filtering_level=4
; Realms are many small stone rooms, which is the case Godot documents occlusion
; culling as most effective for. Without it every light, decal and particle
; system in chambers the raider cannot see is still submitted. The occluders
; themselves are emitted by the realm designs (BoxKit.Structure), not baked in
; the editor, so this switch is all that is needed to turn them on.
occlusion_culling/use_occlusion_culling=true
